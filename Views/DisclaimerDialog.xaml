<Window x:Class="Dorothy.Views.DisclaimerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Settings – Authorization Required"
        Icon="pack://application:,,,/Resources/icon.ico"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A2332"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Advanced Settings – Authorization Required"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#E8ECF1"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Authorization Notice"
                       FontSize="12"
                       Foreground="#8899AA"
                       Margin="0,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#232F3E"
                BorderBrush="#3A4555"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border Background="#3A3520"
                            BorderBrush="#6B5B10"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠"
                                       FontSize="20"
                                       Foreground="#FBBF24"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Restricted Area – Authorized Operations Only"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#FBBF24"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock FontSize="13"
                               Foreground="#C8D1DC"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Margin="0,0,0,20">
                        <Run Text="This section of the application is intended " FontSize="13"/>
                        <Run Text="only for authorized operations" FontSize="13" FontWeight="Bold" Foreground="#F87171"/>
                        <Run Text=" and is " FontSize="13"/>
                        <Run Text="not to be used for testing or experimentation" FontSize="13" FontWeight="Bold" Foreground="#F87171"/>
                        <Run Text=". Use of these functions without proper authorization is " FontSize="13"/>
                        <Run Text="strictly prohibited" FontSize="13" FontWeight="Bold" Foreground="#F87171"/>
                        <Run Text="." FontSize="13"/>
                        <LineBreak/><LineBreak/>
                        <Run Text="Before using this tool, you " FontSize="13"/>
                        <Run Text="must obtain an official written authorization letter" FontSize="13" FontWeight="Bold" Foreground="#F87171"/>
                        <Run Text=" from all related organizations or stakeholders and submit it to the system administrator. " FontSize="13"/>
                        <Run Text="Do not proceed unless you have received explicit confirmation of approval" FontSize="13" FontWeight="Bold" Foreground="#F87171"/>
                        <Run Text="." FontSize="13"/>
                    </TextBlock>

                    <Border Background="#2A3444"
                            BorderBrush="#3A4555"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,8,0,0">
                        <TextBlock FontSize="12"
                                   Foreground="#C8D1DC"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   LineHeight="20">
                            <Run Text="Unauthorized use " FontWeight="Bold" Foreground="#F87171"/>
                            <Run Text="may be illegal and is " FontWeight="SemiBold"/>
                            <Run Text="strictly prohibited" FontWeight="Bold" Foreground="#F87171"/>
                            <Run Text="." FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BackButton"
                        Content="Back"
                        Width="120"
                        Height="42"
                        FontSize="14"
                        Margin="0,0,12,0"
                        Click="BackButton_Click"
                        Background="#3A4555"
                        Foreground="#E8ECF1"
                        BorderBrush="#4A5565"
                        BorderThickness="1"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="12,8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4A5565"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#2A3444"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="ContinueButton"
                        Content="Acknowledged"
                        Width="180"
                        Height="42"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Click="ContinueButton_Click"
                        Background="#5B8AF5"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="12,8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4A79E4"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#3A68D3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
