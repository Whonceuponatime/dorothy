<Window x:Class="Dorothy.Views.AssetSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dorothy.Views"
        Title="Sync Assets to Cloud"
        Icon="pack://application:,,,/Resources/icon.ico"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBg}">
    <Window.Resources>
        <Style x:Key="DefaultButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHover}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DefaultButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Sync Assets to Cloud"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Select assets to sync to Supabase or delete from local database."
                       FontSize="12"
                       Foreground="{DynamicResource TextMuted}"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Margin="0,60,0,12" Orientation="Horizontal">
            <TextBlock Text="Project Name:"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBox x:Name="ProjectNameTextBox"
                     Width="300"
                     Height="32"
                     Padding="8,6"
                     BorderBrush="{DynamicResource BorderDefault}"
                     BorderThickness="1"
                     Background="{DynamicResource SecondaryBg}"
                     FontSize="12"
                     TextChanged="ProjectNameTextBox_TextChanged"/>
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{DynamicResource SecondaryBg}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="SelectAllCheckBox"
                          Content="Select All"
                          FontSize="12"
                          Margin="12,8"
                          Checked="SelectAllCheckBox_Checked"
                          Unchecked="SelectAllCheckBox_Unchecked"/>

                <DataGrid x:Name="AssetsDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          SelectionMode="Extended"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="IP Address" Binding="{Binding HostIp}" Width="120"/>
                        <DataGridTextColumn Header="Hostname" Binding="{Binding HostName}" Width="150"/>
                        <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="130"/>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="120"/>
                        <DataGridTextColumn Header="Status" Width="80">
                            <DataGridTextColumn.Binding>
                                <Binding Path="IsOnline">
                                    <Binding.Converter>
                                        <local:BoolToStatusConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ports" Binding="{Binding OpenPortsDisplay}" Width="150"/>
                        <DataGridTextColumn Header="Ping (ms)" Binding="{Binding PingTime}" Width="80"/>
                        <DataGridTextColumn Header="Scan Time" Binding="{Binding ScanTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="SelectedCountText"
                       Text="0 of 0 selected"
                       FontSize="12"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            <Button x:Name="DeleteSelectedButton"
                    Content="Delete Selected"
                    Width="130"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="DeleteSelectedButton_Click"
                    Style="{StaticResource DefaultButton}"/>
            <Button x:Name="SkipSelectedButton"
                    Content="Skip Selected"
                    Width="120"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="SkipSelectedButton_Click"
                    Style="{StaticResource DefaultButton}"/>
            <Button x:Name="SyncButton"
                    Content="Sync Selected"
                    Width="120"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="SyncButton_Click"
                    Style="{StaticResource PrimaryButton}"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="100"
                    Height="36"
                    Click="CancelButton_Click"
                    Style="{StaticResource DefaultButton}"/>
        </StackPanel>
    </Grid>
</Window>

