<Window x:Class="Dorothy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Icon="pack://application:,,,/Resources/icon.ico"
        Height="500"
        Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="400"
        MinWidth="500"
        Background="{DynamicResource PrimaryBg}">
    <Window.Resources>
        <Style x:Key="DialogButtonBase" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background"      Value="{DynamicResource BorderDefault}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderHover}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background"      Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,20">
            <StackPanel>

            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Log File Location"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LogLocationTextBox"
                                 Grid.Column="0"
                                 Height="32"
                                 Padding="8,6"
                                 Background="{DynamicResource TertiaryBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderDefault}"
                                 BorderThickness="1"
                                 Margin="0,0,8,0"
                                 IsReadOnly="True"/>
                        <Button x:Name="BrowseLogLocationButton"
                                Grid.Column="1"
                                Content="Browse..."
                                Width="80"
                                Height="32"
                                Style="{StaticResource SecondaryBtn}"
                                Click="BrowseLogLocationButton_Click"/>
                    </Grid>
                    <TextBlock Text="Default: Application installation directory"
                               FontSize="10"
                               Foreground="{DynamicResource DisabledFg}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="UI Preferences"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Font Size (8-24px)"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FontSizeTextBox"
                                     Grid.Column="0"
                                     Height="32"
                                     Padding="8,6"
                                     Background="{DynamicResource TertiaryBg}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderDefault}"
                                     BorderThickness="1"
                                     Margin="0,0,8,0"
                                     PreviewTextInput="FontSizeTextBox_PreviewTextInput"
                                     TextChanged="FontSizeTextBox_TextChanged"/>
                            <TextBlock Grid.Column="1"
                                       Text="px"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Enter a custom font size between 8 and 24 pixels"
                                   FontSize="10"
                                   Foreground="{DynamicResource DisabledFg}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Theme"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,4"/>
                        <ComboBox x:Name="ThemeComboBox"
                                  Height="32"
                                  Background="{DynamicResource TertiaryBg}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  BorderBrush="{DynamicResource BorderDefault}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Dark (Default)"/>
                            <ComboBoxItem Content="Light (Coming Soon)"/>
                        </ComboBox>
                        <TextBlock Text="Light theme is not yet available. All dialogs currently use the dark palette."
                                   FontSize="10"
                                   Foreground="{DynamicResource DisabledFg}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Cloud Sync"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Attack logs and assets are synced to your licensed Seacure server."
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Connection Status"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,4"/>
                        <Border Background="{DynamicResource TertiaryBg}"
                                BorderBrush="{DynamicResource BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8">
                            <StackPanel>
                                <TextBlock x:Name="SupabaseUrlTextBlock"
                                           Text="API endpoint: Loading..."
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="ApiConnectionStatusTextBlock"
                                           Text="Checking connection..."
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="License Status"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Licenses are issued by the Seacure licensing server (api.seacuredb.com)."
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"/>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Your Hardware ID"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <Border Background="{DynamicResource TertiaryBg}"
                                BorderBrush="{DynamicResource BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock x:Name="CurrentHardwareIdTextBlock"
                                           Text="Loading..."
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"/>
                                <Button Content="Copy to Clipboard"
                                        FontSize="10"
                                        Padding="8,4"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource BorderDefault}"
                                        Foreground="{DynamicResource TextPrimary}"
                                        BorderBrush="{DynamicResource BorderHover}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="CopyHardwareIdButton_Click"/>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="LicenseStatusTextBlock"
                                   Text="Checking..."
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,8,0,4"/>
                        <TextBlock x:Name="LicenseMessageTextBlock"
                                   Text=""
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,0"/>
                    </StackPanel>

                    <Border Background="{DynamicResource AccentBlueSubtle}"
                            BorderBrush="{DynamicResource LabModeBorder}"
                            BorderThickness="1"
                            Padding="16"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="[?] License Not Authorized?"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource InfoBlue}"
                                       Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="11"
                                       Foreground="{DynamicResource InfoBlue}"
                                       LineHeight="18">
                                <Run Text="To request a license for this machine:"/>
                                <LineBreak/><LineBreak/>
                                <Run Text="1. First, log into api.seacuredb.com and go to Licensing"/>
                                <LineBreak/>
                                <Run Text="2. Then request for a license"/>
                                <LineBreak/>
                                <Run Text="3. Ask or tell the admin to approve of the request"/>
                                <LineBreak/>
                                <Run Text="4. Once approved, restart the application"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource TertiaryBg}"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="6"
                            Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="[i] Centralized License Control"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="All licenses are managed through the Seacure API by the administrator. Users cannot self-authorize to ensure security and compliance."
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 2.6.0 offline-persistence rework: surveyors accumulate scans
                 across launches. Once an engagement has been submitted (or if
                 the surveyor wants a clean slate before the next assessment),
                 this wipes ALL scan/topology rows. Engagements metadata is
                 preserved. -->
            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Local Data"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Permanently deletes all scan data from this device, including unsubmitted assessments. Submitted engagements remain on SEACUREDB. This cannot be undone."
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <Button x:Name="ClearLocalDataButton"
                            Content="Clear all local scan data"
                            FontSize="12"
                            Padding="12,6"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource FieldErrorBg}"
                            Foreground="{DynamicResource ErrorRed}"
                            BorderBrush="{DynamicResource FieldErrorBorder}"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="ClearLocalDataButton_Click"/>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryBtn}"
                    Click="CancelButton_Click"/>
            <Button x:Name="SaveButton"
                    Content="Save"
                    Width="100"
                    Height="36"
                    Style="{StaticResource PrimaryBtn}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
