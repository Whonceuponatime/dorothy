<Window x:Class="Dorothy.Views.EngagementSubmitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Submit assessment"
        Width="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBg}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Submit assessment"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,12"/>

        <!-- Step 1: engagement metadata form -->
        <Border x:Name="MetadataPanel"
                Grid.Row="1"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12"
                Background="{DynamicResource SecondaryBg}">
            <StackPanel>
                <TextBlock x:Name="SessionStatsText"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Engagement name (required)"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NameTextBox"
                         Height="32"
                         Padding="8,6"
                         FontSize="13"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Vessel / Client (optional)"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="ClientTextBox"
                         Height="32"
                         Padding="8,6"
                         FontSize="13"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Scope (optional — CIDR list or free text)"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="ScopeTextBox"
                         Height="32"
                         Padding="8,6"
                         FontSize="13"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Notes (optional)"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NotesTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="64"
                         Padding="8,6"
                         FontSize="13"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>

        <!-- Step 2: confirmation summary -->
        <Border x:Name="ConfirmPanel"
                Grid.Row="1"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12"
                Visibility="Collapsed"
                Background="{DynamicResource SecondaryBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Engagement:"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ConfirmNameText"
                           Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Client:"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ConfirmClientText"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Hosts discovered:"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="HostsDiscoveredText"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Hosts probed in detail:"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="HostsProbedText"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Attack runs:"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="AttackRunsText"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="6" Grid.Column="0" x:Name="SubnetsLabel"
                           Text="Subnets discovered:"
                           Foreground="{DynamicResource TextMuted}"
                           Visibility="Collapsed"/>
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="SubnetsText"
                           Foreground="{DynamicResource TextPrimary}"
                           Visibility="Collapsed"/>

                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                            Margin="0,16,0,0">
                    <CheckBox x:Name="ClearLocalDataCheckbox"
                              Content="Clear local scan data after successful upload"
                              IsChecked="False"
                              FontSize="13"
                              Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Removes all submitted scans from this device. Useful to start fresh for the next assessment. Submitted engagements remain on SEACUREDB regardless."
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="22,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="StatusPanel"
                Grid.Row="2"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12"
                Visibility="Collapsed"
                Background="{DynamicResource SecondaryBg}">
            <StackPanel>
                <ProgressBar x:Name="ProgressBar"
                             IsIndeterminate="True"
                             Height="4"
                             Margin="0,0,0,8"/>
                <TextBlock x:Name="StatusText"
                           Text="Working…"
                           FontSize="13"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Height="32"
                    Width="100"
                    Margin="0,0,8,0"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
            <Button x:Name="BackButton"
                    Content="Back"
                    Height="32"
                    Width="100"
                    Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Cursor="Hand"
                    Click="BackButton_Click"/>
            <Button x:Name="PrimaryButton"
                    Content="Continue"
                    Height="32"
                    Width="120"
                    Cursor="Hand"
                    Click="PrimaryButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
