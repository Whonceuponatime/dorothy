<Window x:Class="Dorothy.Views.ReachabilityHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reachability Run History"
        Height="480" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBg}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select a run to load its results"
                   FontSize="12"
                   Foreground="{DynamicResource TextMuted}"
                   Margin="0,0,0,8"/>

        <ListView x:Name="RunsListView" Grid.Row="1"
                  Background="{DynamicResource SecondaryBg}"
                  BorderBrush="{DynamicResource BorderDefault}"
                  Foreground="{DynamicResource TextPrimary}"
                  MouseDoubleClick="RunsListView_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Started" Width="140" DisplayMemberBinding="{Binding StartedDisplay}"/>
                    <GridViewColumn Header="Label"   Width="220" DisplayMemberBinding="{Binding Label}"/>
                    <GridViewColumn Header="Target"  Width="140" DisplayMemberBinding="{Binding TargetRaw}"/>
                    <GridViewColumn Header="Tested" Width="60"  DisplayMemberBinding="{Binding HostsTested}"/>
                    <GridViewColumn Header="OK"      Width="40" DisplayMemberBinding="{Binding HostsReachable}"/>
                    <GridViewColumn Header="Partial" Width="50" DisplayMemberBinding="{Binding HostsPartial}"/>
                    <GridViewColumn Header="Unreach" Width="60" DisplayMemberBinding="{Binding HostsUnreachable}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="DeleteButton" Content="Delete" MinWidth="80" Margin="0,0,8,0" Click="DeleteButton_Click"/>
            <Button x:Name="LoadButton"   Content="Load"   MinWidth="80" Margin="0,0,8,0" Click="LoadButton_Click" IsDefault="True"/>
            <Button x:Name="CloseButton"  Content="Close"  MinWidth="80" Click="CloseButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
