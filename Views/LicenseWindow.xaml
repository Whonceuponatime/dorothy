<Window x:Class="Dorothy.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Validation"
        Height="400"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/icon.ico"
        Background="{DynamicResource PrimaryBg}">
    <Window.Resources>

        <Style x:Key="DefaultButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource DisabledFg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔒 License Required"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="This application requires a valid license to run."
                       FontSize="12"
                       Foreground="{DynamicResource TextMuted}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Hardware ID:"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Padding="12,8"
                    Margin="0,0,0,16">
                <TextBlock x:Name="HardwareIdTextBlock"
                           Text="Loading..."
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="Status:"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="1"
                    Padding="12,8"
                    Margin="0,0,0,16">
                <TextBlock x:Name="StatusTextBlock"
                           Text="Validating..."
                           FontSize="11"
                           Foreground="{DynamicResource TextMuted}"
                           TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="Instructions:"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource TextMuted}"
                       LineHeight="18"
                       Margin="0,0,0,8">
                <Run Text="1. Click 'Request License' below to submit a request&#x0a;"/>
                <Run Text="2. Ask the admin to approve the request in seacuredb&#x0a;"/>
                <Run Text="3. Once approved, click 'Restart Application' below"/>
            </TextBlock>

            <Button x:Name="RequestLicenseButton"
                    Content="Request License"
                    Click="RequestLicense_Click"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0"
                    Padding="12,6"
                    IsEnabled="True"
                    Style="{StaticResource DefaultButton}"/>

            <TextBlock x:Name="RequestStatusText"
                       Text=""
                       FontSize="11"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"
                       Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CopyIdButton"
                    Content="Copy Hardware ID"
                    Width="140"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="CopyIdButton_Click"
                    Style="{StaticResource DefaultButton}"/>
            <Button x:Name="RestartButton"
                    Content="🔄 Restart Application"
                    Width="180"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="RestartButton_Click"
                    Style="{StaticResource DefaultButton}"/>
            <Button x:Name="ExitButton"
                    Content="Exit"
                    Width="100"
                    Height="36"
                    Click="ExitButton_Click"
                    Style="{StaticResource DefaultButton}"/>
        </StackPanel>
    </Grid>
</Window>

