                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"
                                                   Content="Rate:">
                                                <Label.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock TextWrapping="Wrap" MaxWidth="320">
