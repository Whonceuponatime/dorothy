                                                    <TextBlock Text="Ethernet Multicast" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="L2 IPv4 multicast" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
