                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=AttackTypeComboBox, Path=SelectedIndex}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Attack Mode"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,0,0,6"/>
