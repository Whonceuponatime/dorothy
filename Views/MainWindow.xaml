<Window x:Class="Dorothy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SEACURE(TOOL) - Network Attack Simulator"
        Icon="pack://application:,,,/Resources/icon.ico"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        MinWidth="900"
        MinHeight="620"
        FontFamily="Segoe UI"
        FontSize="12"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="{StaticResource PrimaryBg}"
        Foreground="{StaticResource TextPrimary}"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Background="{StaticResource SecondaryBg}"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#F0F2F5"
                            BorderBrush="#D8DEE4"
                            BorderThickness="0.5"
                            CornerRadius="6"
                            Padding="3"
                            Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <Image x:Name="LogoImage"
                               Source="/Resources/logo.png"
                               Height="32"
                               Width="32"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0">
                        <TextBlock Text="Network Attack Simulator"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,1"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cyber Security Solution by SEANET"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Border x:Name="LabModeBadge"
                                    Background="#1e3a5f"
                                    BorderBrush="#2563eb"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="7,1"
                                    VerticalAlignment="Center"
                                    Cursor="Help">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="420">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Text="Running as Administrator"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                                       Text="Raw packet generation (flood attacks, Layer-2 injection via Npcap/SharpPcap) requires elevated access to open packet capture devices. The application is therefore always launched as Administrator."
                                                       Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#9CA3AF"
                                                       Text="TCP Connect Scan and Reachability Test features do not inherently require Administrator, but the application runs elevated because raw packet generation is the primary workflow."/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock x:Name="LabModeText"
                                           Text="LAB MODE  🔒"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#60a5fa"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="0,0,20,0">
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Packets Sent"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="PacketsSentText"
                                       Text="0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Elapsed Time"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="ElapsedTimeText"
                                       Text="00:00:00"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Actual Rate"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="320">
                                            L2 wire-rate (EMA ~1 s). Accounts for Ethernet header + FCS (+4 B).
                                            Does not include preamble or inter-frame gap (added by NIC hardware).
                                        </TextBlock>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock x:Name="MbpsSentText"
                                       Text="—"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Target Rate"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="TargetRateText"
                                       Text="—"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="vs Target"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="RateDeltaText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" MaxWidth="220" Margin="0,0,0,0">
                            <TextBlock FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2">
                                <Run Text="Likely cause"/>
                                <Run Text=" (heuristic)" Foreground="{StaticResource TextMuted}" FontStyle="Italic"/>
                            </TextBlock>
                            <TextBlock x:Name="DiagnosticReasonText"
                                       Text="—"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="400">
                                            <TextBlock FontWeight="SemiBold" FontSize="12"
                                                       Text="Likely cause (heuristic)"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="DiagnosticReasonTooltipText"
                                                       TextWrapping="Wrap" FontSize="12"
                                                       Text="No diagnostic information yet."/>
                                            <TextBlock Foreground="#9CA3AF" FontSize="10"
                                                       TextWrapping="Wrap" Margin="0,6,0,0"
                                                       Text="All causes are inferred from scheduler counters, not directly measured. Confidence shows the evidential strength of the inference."/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock x:Name="ConfidenceText"
                                       Text="—"
                                       FontSize="9"
                                       Foreground="{StaticResource TextMuted}"
                                       FontStyle="Italic"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="320"
                                                   Text="Confidence is estimated from the strength of the observable scheduler counter evidence. High = direct counter. Medium = one indirect indicator. Low = weak signal that may be misclassified."/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="1"
                                Height="28"
                                Background="{StaticResource BorderDefault}"
                                Margin="10,0,14,0"
                                VerticalAlignment="Center"/>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Profile"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="ProfileSummaryText"
                                       Text=""
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                MinWidth="140"
                                ClipToBounds="False"
                                Margin="8,0,20,0">
                        <Button x:Name="CloudSyncButton"
                                MinWidth="36"
                                MinHeight="36"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ClipToBounds="False"
                                ToolTip="Cloud Sync"
                                Click="CloudSyncButton_Click"
                                Margin="0,0,8,0">
                            <Grid ClipToBounds="False">
                                <TextBlock Text="☁"
                                           FontSize="18"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="CloudSyncNotificationBadge"
                                        Background="{StaticResource ErrorRed}"
                                        CornerRadius="9"
                                        MinWidth="16"
                                        Height="16"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,0,0,0"
                                        Padding="3,1"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="CloudSyncNotificationText"
                                               Text="0"
                                               Foreground="White"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                        <Button x:Name="SettingsButton"
                                MinWidth="36"
                                MinHeight="36"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ClipToBounds="False"
                                ToolTip="Settings"
                                Margin="0,0,4,0"
                                Click="SettingsButton_Click">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#94a3b8" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="HelpButton"
                                MinWidth="36"
                                MinHeight="36"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ClipToBounds="False"
                                ToolTip="Help / About"
                                Margin="0,0,0,0"
                                Click="HelpButton_Click">
                            <Grid ClipToBounds="False">
                                <TextBlock Text="ⓘ"
                                           FontSize="18"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="UpdateAvailableBadge"
                                        Background="{StaticResource ErrorRed}"
                                        BorderBrush="{StaticResource SecondaryBg}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        Width="10"
                                        Height="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,0,0,0"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Border x:Name="StatusBadge"
                            Grid.Column="4"
                            Background="{StaticResource SuccessBgSubtle}"
                            BorderBrush="{StaticResource SuccessBorder}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="10,4"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Height="28">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot"
                                     Width="8"
                                     Height="8"
                                     Fill="{StaticResource SuccessGreen}"
                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusBadgeText"
                                       Text="Ready"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource SuccessGreen}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="16,16,16,16" x:Name="MainContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="420"/>
                    <ColumnDefinition Width="1*" MinWidth="400"/>
                </Grid.ColumnDefinitions>

                <TabControl x:Name="MainTabControl"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            SelectionChanged="MainTabControl_SelectionChanged"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent">

                    <TabItem Header="Basic Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0" HorizontalAlignment="Stretch">
                            <StackPanel Grid.IsSharedSizeScope="True" HorizontalAlignment="Stretch">

                                <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
                                    <StackPanel HorizontalAlignment="Stretch">
                                        <TextBlock Text="Interface &amp; Source" Style="{StaticResource CardHeaderStyle}"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="NIC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <ComboBox x:Name="NetworkInterfaceComboBox"
                                                      Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                                      Margin="0,0,0,10"
                                                      SelectionChanged="NetworkInterfaceComboBox_SelectionChanged"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Source IP:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="SourceIpTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     TextChanged="SourceIpTextBox_TextChanged"/>
                                            <Button x:Name="RefreshSourceIpButton"
                                                    Grid.Row="1" Grid.Column="2"
                                                    Content="Refresh"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="RefreshSourceIpButton_Click"
                                                    ToolTip="Refresh source IP from selected network interface"/>

                                            <Label Grid.Row="2" Grid.Column="0" Content="Source MAC:"
                                                   VerticalAlignment="Center"
                                                   ToolTip="Auto-detected from the selected NIC. Read-only."
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="SourceMacTextBox"
                                                     Grid.Row="2" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,0,10"
                                                     IsReadOnly="True"
                                                     ToolTip="Hardware address of the selected interface — auto-populated, cannot be edited."/>

                                            <Label Grid.Row="3" Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0">
                                                <Label.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                                            Required when the target IP is on a different subnet.
                                                            Frames to remote hosts are sent to the gateway MAC,
                                                            not the remote host MAC.
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Label.ToolTip>
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Text="Gateway IP:" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="cross-subnet" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Label>
                                            <TextBox x:Name="GatewayIpTextBox"
                                                     Grid.Row="3" Grid.Column="1"
                                                     Height="30"
                                                     ToolTip="Router/gateway IP. Required when the target is on a different subnet."
                                                     TextChanged="GatewayIpTextBox_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Target" Style="{StaticResource CardHeaderStyle}"/>
                                        <TextBlock Text="Destination host and port for the test."
                                                   FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,-10,0,12"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="Target IP:"
                                                   VerticalAlignment="Center"
                                                   ToolTip="IPv4 address of the destination host"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="TargetIpTextBox"
                                                     Grid.Row="0" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     Background="{DynamicResource InputBg}"
                                                     Foreground="{DynamicResource TextPrimary}"
                                                     BorderBrush="{DynamicResource BorderDefault}"
                                                     ToolTip="IPv4 address of the destination host to test"
                                                     TextChanged="TargetIpTextBox_TextChanged"/>
                                            <Button x:Name="PingButton"
                                                    Grid.Row="0" Grid.Column="2"
                                                    Content="Ping"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="PingButton_Click"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Dest./Next-hop MAC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"
                                                   ToolTip="On-link target: destination host MAC. Routed target: next-hop gateway MAC (remote host MAC is not reachable across routed hops)."/>
                                            <TextBox x:Name="TargetMacTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     IsReadOnly="True"
                                                     TextChanged="TargetMacTextBox_TextChanged"/>
                                            <Button x:Name="ResolveMacButton"
                                                    Grid.Row="1" Grid.Column="2"
                                                    Content="Resolve"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="ResolveMacButton_Click"/>

                                            <CheckBox x:Name="MacFallbackCheckBox"
                                                      Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                      Content="Allow manual MAC entry"
                                                      Margin="0,0,0,4"
                                                      Checked="MacFallbackCheckBox_Checked"
                                                      Unchecked="MacFallbackCheckBox_Unchecked"/>

                                            <TextBlock x:Name="MacRouteHintText"
                                                       Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Margin="0,0,0,8"
                                                       Visibility="Collapsed"/>

                                            <Label Grid.Row="4" Grid.Column="0" Content="Target Port:"
                                                   VerticalAlignment="Top"
                                                   Margin="0,0,16,0"
                                                   ToolTip="TCP/UDP destination port. Use 0 for ICMP (no port concept)."/>
                                            <Grid Grid.Row="4" Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBox x:Name="TargetPortTextBox"
                                                         Height="30"
                                                         Margin="0,0,8,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         Text="0"/>
                                                <ProgressBar x:Name="ScanProgressBar"
                                                             Grid.Row="1"
                                                             Height="5"
                                                             Margin="0,4,8,0"
                                                             Visibility="Collapsed"/>
                                            </Grid>
                                            <Button x:Name="ScanButton"
                                                    Grid.Row="4" Grid.Column="2"
                                                    Content="Scan"
                                                    Width="80"
                                                    Height="30"
                                                    VerticalAlignment="Top"
                                                    Click="ScanButton_Click"/>
                                        </Grid>

                                        <StackPanel x:Name="DestinationTypePanel" Margin="0,12,0,0">
                                            <TextBlock Text="Destination Type"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11"
                                                       Margin="0,0,0,4"/>
                                            <UniformGrid Columns="3">
                                                <RadioButton x:Name="UnicastRadio"
                                                             Content="Unicast"
                                                             GroupName="DestType"
                                                             IsChecked="True"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             FontSize="11"
                                                             Margin="0,0,4,0"
                                                             Checked="DestType_Changed"/>
                                                <RadioButton x:Name="MulticastRadio"
                                                             Content="Multicast"
                                                             GroupName="DestType"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             FontSize="11"
                                                             Margin="0,0,4,0"
                                                             Checked="DestType_Changed"/>
                                                <RadioButton x:Name="BroadcastRadio"
                                                             Content="Broadcast"
                                                             GroupName="DestType"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             FontSize="11"
                                                             Checked="DestType_Changed"/>
                                            </UniformGrid>
                                            <TextBlock x:Name="DestTypeHintText"
                                                       Text=""
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Protocol &amp; Rate" Style="{StaticResource CardHeaderStyle}"/>

                                        <UniformGrid x:Name="ProtocolCardsPanel" Columns="2" Margin="0,0,0,8">
                                            <Border Tag="0" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="TCP SYN" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="Half-open flood" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="1" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="UDP" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="Datagram flood" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
