                                                    <TextBlock Text="Echo-request flood" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="3" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
