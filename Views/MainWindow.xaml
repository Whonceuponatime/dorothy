<Window x:Class="Dorothy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Dorothy.Views"
        Title="SEACURE(TOOL) - Network Attack Simulator"
        Icon="pack://application:,,,/Resources/icon.ico"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        MinWidth="900"
        MinHeight="620"
        FontFamily="Segoe UI"
        FontSize="12"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="{DynamicResource PrimaryBg}"
        Foreground="{DynamicResource TextPrimary}"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="52"/>
                <RowDefinition Height="Auto"/>     <!-- License stale banner — Auto = 0 when collapsed -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Background="{DynamicResource SecondaryBg}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource LogoBg}"
                            BorderBrush="{DynamicResource LogoBorder}"
                            BorderThickness="0.5"
                            CornerRadius="6"
                            Padding="8"
                            Margin="8,8"
                            Height="72"
                            VerticalAlignment="Center">
                        <Image x:Name="LogoImage"
                               Source="/Resources/logo.png"
                               MaxHeight="56"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0">
                        <TextBlock Text="Network Attack Simulator"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,1"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cyber Security Solution by SEANET"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Border x:Name="LabModeBadge"
                                    Background="{DynamicResource LabModeBg}"
                                    BorderBrush="{DynamicResource LabModeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="7,1"
                                    VerticalAlignment="Center"
                                    Cursor="Help">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="420">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Text="Running as Administrator"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                                       Text="Raw packet generation (flood attacks, Layer-2 injection via Npcap/SharpPcap) requires elevated access to open packet capture devices. The application is therefore always launched as Administrator."
                                                       Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource DisabledFg}"
                                                       Text="TCP Connect Scan and Reachability Test features do not inherently require Administrator, but the application runs elevated because raw packet generation is the primary workflow."/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock x:Name="LabModeText"
                                           Text="LAB MODE  🔒"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource LabModeFg}"/>
                            </Border>
                            <Border x:Name="AppEditionBadge"
                                    Background="{DynamicResource LabModeBg}"
                                    BorderBrush="{DynamicResource LabModeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="7,1"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="AppEditionBadgeText"
                                           Text=""
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource LabModeFg}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="0,0,20,0">
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Packets Sent"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="PacketsSentText"
                                       Text="0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Elapsed Time"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="ElapsedTimeText"
                                       Text="00:00:00"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Actual Rate"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="320">
                                            L2 wire-rate (EMA ~1 s). Accounts for Ethernet header + FCS (+4 B).
                                            Does not include preamble or inter-frame gap (added by NIC hardware).
                                        </TextBlock>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock x:Name="MbpsSentText"
                                       Text="—"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="Target Rate"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="TargetRateText"
                                       Text="—"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,18,0">
                            <TextBlock Text="vs Target"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="RateDeltaText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" MaxWidth="220" Margin="0,0,0,0">
                            <TextBlock FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2">
                                <Run Text="Likely cause"/>
                                <Run Text=" (heuristic)" Foreground="{DynamicResource TextMuted}" FontStyle="Italic"/>
                            </TextBlock>
                            <TextBlock x:Name="DiagnosticReasonText"
                                       Text="—"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="400">
                                            <TextBlock FontWeight="SemiBold" FontSize="12"
                                                       Text="Likely cause (heuristic)"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="DiagnosticReasonTooltipText"
                                                       TextWrapping="Wrap" FontSize="12"
                                                       Text="No diagnostic information yet."/>
                                            <TextBlock Foreground="{DynamicResource DisabledFg}" FontSize="10"
                                                       TextWrapping="Wrap" Margin="0,6,0,0"
                                                       Text="All causes are inferred from scheduler counters, not directly measured. Confidence shows the evidential strength of the inference."/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock x:Name="ConfidenceText"
                                       Text="—"
                                       FontSize="9"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontStyle="Italic"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="320"
                                                   Text="Confidence is estimated from the strength of the observable scheduler counter evidence. High = direct counter. Medium = one indirect indicator. Low = weak signal that may be misclassified."/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="1"
                                Height="28"
                                Background="{DynamicResource BorderDefault}"
                                Margin="10,0,14,0"
                                VerticalAlignment="Center"/>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Profile"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,2"/>
                            <TextBlock x:Name="ProfileSummaryText"
                                       Text=""
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                ClipToBounds="False"
                                Margin="0,0,16,0">
                        <Button x:Name="SubmitAssessmentButton"
                                Content="Submit assessment"
                                Height="32"
                                Padding="12,6"
                                FontSize="12"
                                Cursor="Hand"
                                IsEnabled="False"
                                ToolTip="No scan activity to submit yet. Run a probe or attack first."
                                Click="SubmitAssessmentButton_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="SettingsButton"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ClipToBounds="False"
                                ToolTip="Settings"
                                Margin="0,0,8,0"
                                Click="SettingsButton_Click">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource TextPrimary}" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="ThemeToggleButton"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ClipToBounds="False"
                                ToolTip="Toggle theme"
                                Margin="0,0,8,0"
                                Click="ThemeToggleButton_Click">
                            <TextBlock x:Name="ThemeToggleIcon"
                                       Text="☀"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="HelpButton"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ClipToBounds="False"
                                ToolTip="Help / About"
                                Margin="0,0,12,0"
                                Click="HelpButton_Click">
                            <Grid ClipToBounds="False">
                                <TextBlock Text="ⓘ"
                                           FontSize="16"
                                           Foreground="{DynamicResource TextPrimary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="UpdateAvailableBadge"
                                        Background="{DynamicResource ErrorRed}"
                                        BorderBrush="{DynamicResource SecondaryBg}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        Width="10"
                                        Height="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,0,0,0"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Border x:Name="StatusBadge"
                                Background="{DynamicResource SuccessBgSubtle}"
                                BorderBrush="{DynamicResource SuccessBorder}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Center"
                                Height="28">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot"
                                         Width="8"
                                         Height="8"
                                         Fill="{DynamicResource SuccessGreen}"
                                         Margin="0,0,6,0"/>
                                <TextBlock x:Name="StatusBadgeText"
                                           Text="Ready"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SuccessGreen}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- License stale banner: yellow strip below the header bar.
                 Visible only when LicenseService transitions to Stale.
                 Refresh button triggers an immediate re-validation;
                 dismiss is user-only (banner reappears on next state change). -->
            <Border x:Name="LicenseStaleBanner"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    Background="#FBBF24"
                    BorderBrush="#F59E0B"
                    BorderThickness="0,0,0,1"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="LicenseStaleBannerText"
                               Grid.Column="0"
                               Text="License unchecked"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button x:Name="LicenseStaleBannerRefreshBtn"
                            Grid.Column="1"
                            Content="Refresh now"
                            Click="LicenseStaleBannerRefresh_Click"
                            Margin="12,0,8,0"
                            Padding="12,4"/>
                    <Button x:Name="LicenseStaleBannerDismissBtn"
                            Grid.Column="2"
                            Content="✕"
                            Click="LicenseStaleBannerDismiss_Click"
                            Padding="6,2"
                            ToolTip="Hide this banner. It will reappear on the next state change."/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="16,16,16,16" x:Name="MainContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="420"/>
                    <ColumnDefinition x:Name="LogColumnDefinition" Width="1*" MinWidth="400"/>
                </Grid.ColumnDefinitions>

                <TabControl x:Name="MainTabControl"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            SelectionChanged="MainTabControl_SelectionChanged"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent">

                    <TabItem x:Name="BasicSettingsTab" Header="Basic Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0" HorizontalAlignment="Stretch">
                            <StackPanel Grid.IsSharedSizeScope="True" HorizontalAlignment="Stretch">

                                <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
                                    <StackPanel HorizontalAlignment="Stretch">
                                        <TextBlock Text="Interface &amp; Source" Style="{StaticResource CardHeaderStyle}"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="NIC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <ComboBox x:Name="NetworkInterfaceComboBox"
                                                      Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                                      Margin="0,0,0,10"
                                                      SelectionChanged="NetworkInterfaceComboBox_SelectionChanged"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Source IP:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="SourceIpTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     TextChanged="SourceIpTextBox_TextChanged"/>
                                            <Button x:Name="RefreshSourceIpButton"
                                                    Grid.Row="1" Grid.Column="2"
                                                    Content="Refresh"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="RefreshSourceIpButton_Click"
                                                    ToolTip="Refresh source IP from selected network interface"/>

                                            <Label Grid.Row="2" Grid.Column="0" Content="Source MAC:"
                                                   VerticalAlignment="Center"
                                                   ToolTip="Auto-detected from the selected NIC. Read-only."
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="SourceMacTextBox"
                                                     Grid.Row="2" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,0,10"
                                                     IsReadOnly="True"
                                                     ToolTip="Hardware address of the selected interface — auto-populated, cannot be edited."/>

                                            <Label Grid.Row="3" Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0">
                                                <Label.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                                            Required when the target IP is on a different subnet.
                                                            Frames to remote hosts are sent to the gateway MAC,
                                                            not the remote host MAC.
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Label.ToolTip>
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Text="Gateway IP:" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="cross-subnet" FontSize="9" Foreground="{DynamicResource TextMuted}" Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Label>
                                            <TextBox x:Name="GatewayIpTextBox"
                                                     Grid.Row="3" Grid.Column="1"
                                                     Height="30"
                                                     ToolTip="Router/gateway IP. Required when the target is on a different subnet."
                                                     TextChanged="GatewayIpTextBox_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Target" Style="{StaticResource CardHeaderStyle}"/>
                                        <TextBlock Text="Destination host and port for the test."
                                                   FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,-10,0,12"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="Target IP:"
                                                   VerticalAlignment="Center"
                                                   ToolTip="IPv4 address of the destination host"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="TargetIpTextBox"
                                                     Grid.Row="0" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     Background="{DynamicResource InputBg}"
                                                     Foreground="{DynamicResource TextPrimary}"
                                                     BorderBrush="{DynamicResource BorderDefault}"
                                                     ToolTip="IPv4 address of the destination host to test"
                                                     TextChanged="TargetIpTextBox_TextChanged"/>
                                            <Button x:Name="PingButton"
                                                    Grid.Row="0" Grid.Column="2"
                                                    Content="Ping"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="PingButton_Click"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Dest./Next-hop MAC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"
                                                   ToolTip="On-link target: destination host MAC. Routed target: next-hop gateway MAC (remote host MAC is not reachable across routed hops)."/>
                                            <TextBox x:Name="TargetMacTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     IsReadOnly="True"
                                                     TextChanged="TargetMacTextBox_TextChanged"/>
                                            <Button x:Name="ResolveMacButton"
                                                    Grid.Row="1" Grid.Column="2"
                                                    Content="Resolve"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="ResolveMacButton_Click"/>

                                            <CheckBox x:Name="MacFallbackCheckBox"
                                                      Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                      Content="Allow manual MAC entry"
                                                      Margin="0,0,0,4"
                                                      Checked="MacFallbackCheckBox_Checked"
                                                      Unchecked="MacFallbackCheckBox_Unchecked"/>

                                            <TextBlock x:Name="MacRouteHintText"
                                                       Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,0,0,8"
                                                       Visibility="Collapsed"/>

                                            <Label Grid.Row="4" Grid.Column="0" Content="Target Port:"
                                                   VerticalAlignment="Top"
                                                   Margin="0,0,16,0"
                                                   ToolTip="TCP/UDP destination port. Use 0 for ICMP (no port concept)."/>
                                            <Grid Grid.Row="4" Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBox x:Name="TargetPortTextBox"
                                                         Height="30"
                                                         Margin="0,0,8,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         Text="0"/>
                                                <ProgressBar x:Name="ScanProgressBar"
                                                             Grid.Row="1"
                                                             Height="5"
                                                             Margin="0,4,8,0"
                                                             Visibility="Collapsed"/>
                                            </Grid>
                                            <Button x:Name="ScanButton"
                                                    Grid.Row="4" Grid.Column="2"
                                                    Content="Scan"
                                                    Width="80"
                                                    Height="30"
                                                    VerticalAlignment="Top"
                                                    Click="ScanButton_Click"/>
                                        </Grid>

                                        <StackPanel x:Name="DestinationTypePanel" Margin="0,12,0,0">
                                            <TextBlock Text="Destination Type"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11"
                                                       Margin="0,0,0,4"/>
                                            <UniformGrid Columns="3">
                                                <RadioButton x:Name="UnicastRadio"
                                                             Content="Unicast"
                                                             GroupName="DestType"
                                                             IsChecked="True"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             FontSize="11"
                                                             Margin="0,0,4,0"
                                                             Checked="DestType_Changed"/>
                                                <RadioButton x:Name="MulticastRadio"
                                                             Content="Multicast"
                                                             GroupName="DestType"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             FontSize="11"
                                                             Margin="0,0,4,0"
                                                             Checked="DestType_Changed"/>
                                                <RadioButton x:Name="BroadcastRadio"
                                                             Content="Broadcast"
                                                             GroupName="DestType"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             FontSize="11"
                                                             Checked="DestType_Changed"/>
                                            </UniformGrid>
                                            <TextBlock x:Name="DestTypeHintText"
                                                       Text=""
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Protocol &amp; Rate" Style="{StaticResource CardHeaderStyle}"/>

                                        <UniformGrid x:Name="ProtocolCardsPanel" Columns="2" Margin="0,0,0,8">
                                            <Border Tag="0" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="TCP SYN" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="Half-open flood" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="1" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="UDP" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="Datagram flood" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="2" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="ICMP" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="Echo-request flood" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="3" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="Ethernet Unicast" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="L2 IPv4 storm" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="5" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="Ethernet Multicast" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="L2 IPv4 multicast" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="7" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
                                                <StackPanel>
                                                    <TextBlock Text="Ethernet Broadcast" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="L2 IPv4 broadcast" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <ComboBox x:Name="AttackTypeComboBox"
                                                  Visibility="Collapsed"
                                                  SelectionChanged="AttackTypeComboBox_SelectionChanged"/>

                                        <TextBlock x:Name="AttackTypeDescText"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"
                                                   Text="Select a protocol to see a description."/>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"
                                                   Content="Rate:">
                                                <Label.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock TextWrapping="Wrap" MaxWidth="320">
                                                            Wire-rate target. Measured at L2: Ethernet header + payload + FCS (+4 B).
                                                            Preamble and IFG are excluded (added by NIC hardware).
                                                            Formula: ActualMbps = wireBytesSent × 8 / (elapsed × 1 000 000)
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Label.ToolTip>
                                            </Label>
                                            <Grid Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="MegabitsPerSecondTextBox"
                                                         Grid.Column="0"
                                                         Height="30"
                                                         Margin="0,0,4,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         PreviewTextInput="MegabitsPerSecondTextBox_PreviewTextInput"
                                                         TextChanged="MegabitsPerSecondTextBox_TextChanged"
                                                         Text="100"
                                                         ToolTip="Enter target rate value (e.g. 100 for 100 Mbps)"/>
                                                <ComboBox x:Name="RateUnitComboBox"
                                                          Grid.Column="1"
                                                          Height="30"
                                                          Padding="6,0"
                                                          ToolTip="Select rate unit"
                                                          SelectionChanged="RateUnitComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Bps"/>
                                                    <ComboBoxItem Content="Kbps"/>
                                                    <ComboBoxItem Content="Mbps" IsSelected="True"/>
                                                    <ComboBoxItem Content="Gbps"/>
                                                </ComboBox>
                                            </Grid>
                                        </Grid>

                                        <StackPanel x:Name="TcpSynModePanel" Margin="0,12,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=AttackTypeComboBox, Path=SelectedIndex}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Attack Mode"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,0,0,6"/>
                                            <UniformGrid x:Name="TcpSynModeGrid" Columns="2">
                                                <Border x:Name="BasicModeCard"
                                                        Tag="Basic"
                                                        Style="{StaticResource ProtocolCardStyle}"
                                                        MouseLeftButtonUp="TcpSynModeCard_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="Basic"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimary}"/>
                                                        <TextBlock Text="Standard SYN — max throughput"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   Margin="0,2,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="EvasionModeCard"
                                                        Tag="Evasion"
                                                        Style="{StaticResource ProtocolCardStyle}"
                                                        MouseLeftButtonUp="TcpSynModeCard_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="Evasion"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimary}"/>
                                                        <TextBlock Text="Firewall bypass — randomised headers"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   Margin="0,2,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>
                                            <TextBlock x:Name="TcpSynModeDescText"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Margin="4,8,0,0"
                                                       Text="Standard TCP SYN packets. Best for raw throughput tests against session tables."/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,4,0,0"
                                        Padding="16,14"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderDefault}"
                                        BorderThickness="1"
                                        Background="{DynamicResource SecondaryBg}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button x:Name="StartButton"
                                                    Content="▶  Start Test"
                                                    Width="148"
                                                    Height="36"
                                                    Style="{StaticResource PrimaryButton}"
                                                    IsEnabled="False"
                                                    Click="StartButton_Click"
                                                    ToolTip="Begin the selected traffic test (requires Administrator)"/>
                                            <Button x:Name="StopButton"
                                                    Content="■  Stop"
                                                    Width="120"
                                                    Height="36"
                                                    Margin="8,0,0,0"
                                                    IsEnabled="False"
                                                    Click="StopButton_Click"
                                                    ToolTip="Halt the running test and display final statistics"/>
                                        </StackPanel>
                                        <Grid>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap">
                                                <Run Text="⚠" Foreground="{DynamicResource WarningAmber}"/>
                                                <Run Text=" Apply only to networks and systems you are authorized to test."/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="FirewallNetworksTab" Header="Network Intelligence">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,8">
                                <WrapPanel Orientation="Horizontal">
                                    <Button x:Name="NiStartDiscoveryButton"
                                            Content="▶  Start discovery"
                                            Style="{StaticResource PrimaryButton}"
                                            MinWidth="140"
                                            Margin="0,0,8,0"
                                            Click="NiStartDiscoveryButton_Click"/>
                                    <Button x:Name="NiStopDiscoveryButton"
                                            Content="■  Stop"
                                            MinWidth="80"
                                            IsEnabled="False"
                                            Margin="0,0,8,0"
                                            Click="NiStopDiscoveryButton_Click"/>

                                    <TextBlock x:Name="NiCurrentScanLabel"
                                               VerticalAlignment="Center"
                                               Margin="4,0,8,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBlue}"
                                               Text=""/>

                                    <TextBlock x:Name="NiConnectivityChip"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"
                                               ToolTip="Internet connectivity status. Updated every 30s."/>

                                    <TextBlock Text="Probe:"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,4,0"/>
                                    <ComboBox x:Name="NiProbeLevelCombo"
                                              Width="110"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              FontSize="11"
                                              SelectionChanged="NiProbeLevelCombo_SelectionChanged"
                                              ToolTip="Reconnaissance intensity for right-click scan + bulk scan.&#10;Reachability test: safe for production ICS networks (default).&#10;Banner grab: standard analyst pass — caution on industrial networks.&#10;Deep scan: pentest mode — explicit warnings on industrial hosts.">
                                        <ComboBoxItem Content="Reachability test" Tag="Survey"/>
                                        <ComboBoxItem Content="Banner grab" Tag="Simple"/>
                                        <ComboBoxItem Content="Deep scan" Tag="Advanced"/>
                                    </ComboBox>

                                    <CheckBox x:Name="NiStealthModeCheckBox"
                                              Content="Stealth mode"
                                              VerticalAlignment="Center"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMuted}"
                                              Margin="0,0,8,0"
                                              ToolTip="Slower scan, lower firewall-trigger risk. Recommended for production environments.&#10;When ON: concurrency 2, 50-200ms jitter, shuffled host order, no retries."
                                              Click="NiStealthModeCheckBox_Click"/>

                                    <Border Width="1"
                                            Height="20"
                                            Background="{DynamicResource BorderDefault}"
                                            Margin="0,4,8,4"/>

                                    <TextBlock Text="NIC:"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,4,0"/>
                                    <ComboBox x:Name="NiNicSelector"
                                              Width="240"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              DisplayMemberPath="Description"
                                              SelectionChanged="NiNicSelector_SelectionChanged"
                                              ToolTip="Network interface used for discovery and probes"/>

                                    <Border Width="1"
                                            Height="20"
                                            Background="{DynamicResource BorderDefault}"
                                            Margin="0,4,8,4"/>

                                    <TextBlock Text="SNMP community:"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBox x:Name="NiSnmpCommunity"
                                             Width="80"
                                             Text="public"
                                             FontFamily="Consolas"
                                             Background="{DynamicResource InputBg}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderDefault}"
                                             Padding="6,4"
                                             Margin="0,0,8,0"/>

                                    <Border Width="1"
                                            Height="20"
                                            Background="{DynamicResource BorderDefault}"
                                            Margin="0,4,8,4"/>

                                    <TextBlock Text="Add subnet:"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,6,0"/>
                                    <TextBox x:Name="NiManualSubnetInput"
                                             Width="160"
                                             FontFamily="Consolas"
                                             Background="{DynamicResource InputBg}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderDefault}"
                                             Padding="6,4"
                                             Margin="0,0,6,0"
                                             ToolTip="CIDR or comma-separated CIDRs&#10;e.g. 192.168.10.0/24, 10.0.0.0/24"
                                             KeyDown="NiManualSubnetInput_KeyDown"/>
                                    <Button x:Name="NiAddSubnetButton"
                                            Content="Add"
                                            MinWidth="60"
                                            Margin="0,0,8,0"
                                            ToolTip="Add manually to topology — no probing yet.&#10;Right-click the new cloud node to expand."
                                            Click="NiAddSubnetButton_Click"/>

                                    <Border Width="1"
                                            Height="20"
                                            Background="{DynamicResource BorderDefault}"
                                            Margin="0,4,8,4"/>

                                    <TextBlock Text="Traceroute to:"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,0,4,0"/>
                                    <TextBox x:Name="NiTracerouteTargetInput"
                                             Width="140"
                                             VerticalAlignment="Center"
                                             FontFamily="Consolas"
                                             Background="{DynamicResource InputBg}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderDefault}"
                                             Padding="6,4"
                                             ToolTip="IP address or hostname to traceroute (e.g. 8.8.8.8)"
                                             Margin="0,0,4,0"/>
                                    <Button x:Name="NiTracerouteRunButton"
                                            Content="Run"
                                            MinWidth="60"
                                            Margin="0,0,8,0"
                                            ToolTip="Render hops as nodes on the canvas, connected by amber TraceroutePath edges."
                                            Click="NiTracerouteRunButton_Click"/>

                                    <Border Width="1"
                                            Height="20"
                                            Background="{DynamicResource BorderDefault}"
                                            Margin="0,4,8,4"/>

                                    <Button x:Name="NiHistoryButton"
                                            Content="History"
                                            MinWidth="80"
                                            Margin="0,0,8,0"
                                            Click="NiHistoryButton_Click"/>
                                    <Button x:Name="NiExportButton"
                                            Content="Export"
                                            MinWidth="80"
                                            Margin="0,0,8,0"
                                            IsEnabled="False"
                                            Click="NiExportButton_Click"/>

                                    <Border Width="1"
                                            Height="20"
                                            Background="{DynamicResource BorderDefault}"
                                            Margin="0,4,8,4"/>

                                    <TextBlock Text="Tip: Click to select one node. Shift+click to add multiple. Shift+drag to box-select."
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="11"
                                               FontStyle="Italic"
                                               Margin="0,0,8,0"
                                               TextWrapping="Wrap"
                                               MaxWidth="320"/>

                                    <Button x:Name="NiRecenterButton"
                                            Content="↻ Center"
                                            MinWidth="80"
                                            Margin="0,0,8,0"
                                            ToolTip="Re-center the topology in the viewport"
                                            Click="NiRecenterButton_Click"/>

                                    <Button x:Name="NiClearTopologyButton"
                                            Content="Clear topology"
                                            MinWidth="110"
                                            ToolTip="Wipe all discovered nodes and edges from the canvas. Cannot be undone."
                                            Click="NiClearTopologyButton_Click"/>
                                </WrapPanel>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="400"/>
                                </Grid.ColumnDefinitions>

                                <views:TopologyCanvasControl x:Name="NiTopologyCanvas"
                                                             Grid.Column="0"/>

                                <!-- Bulk probe progress overlay. Hosted in a Popup (its own
                                     top-level Win32 window) so it isn't hidden by WebView2's
                                     native HWND airspace. Anchored to NiTopologyCanvas's
                                     top-left via RelativePoint placement; HorizontalOffset is
                                     computed at runtime from the canvas's ActualWidth so the
                                     popup pins to the top-right corner regardless of window
                                     size. VerticalOffset stays a constant 20 (top edge inset). -->
                                <Popup x:Name="NiBulkProbeOverlay"
                                       IsOpen="False"
                                       Placement="RelativePoint"
                                       PlacementTarget="{Binding ElementName=NiTopologyCanvas}"
                                       AllowsTransparency="True"
                                       StaysOpen="True"
                                       HorizontalOffset="20"
                                       VerticalOffset="20">
                                    <Border Background="{DynamicResource SecondaryBg}"
                                            BorderBrush="{DynamicResource AccentBlue}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="16,8"
                                            MaxWidth="500">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Ellipse x:Name="NiBulkSpinner"
                                                         Grid.Column="0"
                                                         Width="16" Height="16"
                                                         Stroke="{DynamicResource AccentBlue}"
                                                         StrokeThickness="2.5"
                                                         StrokeDashArray="3,2"
                                                         Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         RenderTransformOrigin="0.5,0.5">
                                                    <Ellipse.RenderTransform>
                                                        <RotateTransform x:Name="NiBulkSpinnerRotate" Angle="0"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>

                                                <TextBlock x:Name="NiBulkOverlayText"
                                                           Grid.Column="1"
                                                           Text="Bulk probe running..."
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Button x:Name="NiBulkCancelButton"
                                                        Grid.Column="2"
                                                        Content="Cancel"
                                                        Margin="12,0,0,0"
                                                        Padding="8,2"
                                                        FontSize="11"
                                                        Click="NiBulkCancelButton_Click"/>
                                            </Grid>

                                            <ProgressBar x:Name="NiBulkProgressBar"
                                                         Height="4"
                                                         Margin="0,8,0,0"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="0"
                                                         Foreground="{DynamicResource AccentBlue}"
                                                         Background="{DynamicResource TertiaryBg}"/>

                                            <TextBlock x:Name="NiBulkDetailText"
                                                       Margin="0,4,0,0"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text=""/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource PrimaryBg}"
                                        BorderBrush="{DynamicResource BorderDefault}"
                                        BorderThickness="1,0,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                        <StackPanel x:Name="NiDetailPanel" Visibility="Collapsed">

                                            <TextBlock x:Name="NiDetailIp"
                                                       FontSize="15"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock x:Name="NiDetailStatus"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock x:Name="NiDetailSummary"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,4"/>
                                            <TextBlock x:Name="NiDetailLastSeen"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="NiDetailProbedAt"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource AccentBlue}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,12"
                                                       Visibility="Collapsed"/>

                                            <StackPanel x:Name="NiDetailVendorSection">
                                                <TextBlock Text="VENDOR / HOST"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,8,0,4"/>
                                                <TextBlock x:Name="NiDetailVendor"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="NiDetailHostname"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailDeviceTypeSection">
                                                <TextBlock Text="DEVICE TYPE"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <TextBlock x:Name="NiDetailDeviceType"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- ICS recon (2.6 Round 1) — industrial-device summary
                                                 + per-protocol detail. Order: Industrial first, then
                                                 Modbus / OPC UA, then IT-side sections (ROUTE, ICMP, …). -->
                                            <StackPanel x:Name="NiDetailIndustrialSection" Visibility="Collapsed">
                                                <TextBlock Text="INDUSTRIAL DEVICE"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailIndustrial">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Key}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource TextMuted}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextPrimary}"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailRouteSection">
                                                <TextBlock Text="ROUTE"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <TextBlock x:Name="NiDetailRoute"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailIcmpSection">
                                                <TextBlock Text="ICMP"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <TextBlock x:Name="NiDetailIcmp"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailPathSection">
                                                <TextBlock Text="PATH"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailTrace">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Display}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="12"
                                                                       Margin="0,1"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{DynamicResource TextPrimary}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailTcpSection">
                                                <TextBlock Text="TCP PORTS"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailTcp">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                <TextBlock Text="{Binding Port}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           MinWidth="50"
                                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                                <TextBlock Text="{Binding Status}"
                                                                           FontSize="11"
                                                                           MinWidth="70"
                                                                           Margin="8,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessGreen}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Filtered">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningAmber}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorRed}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Service}"
                                                                           FontSize="11"
                                                                           MinWidth="90"
                                                                           Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                                <TextBlock Text="{Binding Version}"
                                                                           FontSize="10"
                                                                           FontStyle="Italic"
                                                                           Foreground="{DynamicResource TextMuted}"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiSnmpSection" Visibility="Collapsed">
                                                <TextBlock Text="SNMP"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailSnmp" Visibility="Collapsed">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Key}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource TextMuted}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailUdpSection" Visibility="Collapsed">
                                                <TextBlock Text="UDP PORTS"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailUdp">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                <TextBlock Text="{Binding Port}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           MinWidth="50"
                                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                                <TextBlock Text="{Binding Status}"
                                                                           FontSize="11"
                                                                           MinWidth="120"
                                                                           Margin="8,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessGreen}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="OpenOrFiltered">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningAmber}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Service}"
                                                                           FontSize="11"
                                                                           MinWidth="100"
                                                                           Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailTlsSection" Visibility="Collapsed">
                                                <TextBlock Text="TLS CERTIFICATE"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailTls">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{DynamicResource BorderDefault}"
                                                                    BorderThickness="0,0,0,1"
                                                                    Padding="0,3"
                                                                    Margin="0,1">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource TextPrimary}"
                                                                               Text="{Binding Header}"/>
                                                                    <TextBlock FontSize="10"
                                                                               FontFamily="Consolas"
                                                                               Foreground="{DynamicResource TextSecondary}"
                                                                               Text="{Binding Subject}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock FontSize="10"
                                                                               Foreground="{DynamicResource TextMuted}"
                                                                               Text="{Binding Issuer}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock FontSize="10"
                                                                               Foreground="{DynamicResource TextMuted}"
                                                                               Text="{Binding Validity}"/>
                                                                    <TextBlock FontSize="10"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource WarningAmber}"
                                                                               Text="{Binding Warning}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Warning}" Value="">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock FontSize="10"
                                                                               Foreground="{DynamicResource TextMuted}"
                                                                               Text="{Binding Sans}"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailHttpSection" Visibility="Collapsed">
                                                <TextBlock Text="HTTP PATHS"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailHttp">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                <TextBlock Text="{Binding Status}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           MinWidth="40"
                                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                                <TextBlock Text="{Binding PortPath}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           MinWidth="160"
                                                                           Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource SuccessGreen}"/>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="11"
                                                                           Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="NiDetailSmbSection" Visibility="Collapsed">
                                                <TextBlock Text="SMB INFO"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,12,0,4"/>
                                                <ItemsControl x:Name="NiDetailSmb">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Key}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource TextMuted}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <Border x:Name="VantagePointBorder"
                                                    Background="{DynamicResource AccentBlueSubtle}"
                                                    BorderBrush="{DynamicResource LabModeBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,12,0,0"
                                                    Visibility="Collapsed">
                                                <TextBlock x:Name="VantagePointText"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource InfoBlue}"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <!-- Probe progress: spinner + indeterminate bar, only visible during a probe run -->
                                            <StackPanel x:Name="NiProbeProgressPanel"
                                                        Visibility="Collapsed"
                                                        Margin="0,12,0,4">
                                                <TextBlock x:Name="NiProbeTargetText"
                                                           Text="Probing..."
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBlue}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="NiProbeSpinner"
                                                             Grid.Column="0"
                                                             Width="14" Height="14"
                                                             Stroke="{DynamicResource AccentBlue}"
                                                             StrokeThickness="2"
                                                             StrokeDashArray="2,2"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center"
                                                             RenderTransformOrigin="0.5,0.5">
                                                        <Ellipse.RenderTransform>
                                                            <RotateTransform x:Name="NiProbeSpinnerRotate" Angle="0"/>
                                                        </Ellipse.RenderTransform>
                                                    </Ellipse>
                                                    <TextBlock x:Name="NiProbeStageText"
                                                               Grid.Column="1"
                                                               Text="Probing..."
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontSize="12"/>
                                                </Grid>
                                                <ProgressBar x:Name="NiProbeProgressBar"
                                                             IsIndeterminate="True"
                                                             Height="3"
                                                             Margin="0,6,0,0"
                                                             Foreground="{DynamicResource AccentBlue}"
                                                             Background="{DynamicResource TertiaryBg}"/>
                                            </StackPanel>

                                            <!-- Banner grab + Deep scan buttons: paired, secondary weight, same height as Set as attack target below -->
                                            <Grid x:Name="NiDetailProbeButtonRow"
                                                  Margin="0,8,0,4"
                                                  Visibility="Collapsed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="NiSimpleProbeButton"
                                                        Grid.Column="0"
                                                        Content="Banner grab"
                                                        Style="{StaticResource DefaultButton}"
                                                        Height="36"
                                                        FontSize="13"
                                                        Click="NiSimpleProbeButton_Click"/>
                                                <Button x:Name="NiAdvancedProbeButton"
                                                        Grid.Column="2"
                                                        Content="Deep scan"
                                                        Style="{StaticResource DefaultButton}"
                                                        Height="36"
                                                        FontSize="13"
                                                        Click="NiAdvancedProbeButton_Click"/>
                                            </Grid>
                                            <Button x:Name="NiDetailSetTargetButton"
                                                    Content="Set as attack target"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Height="36"
                                                    FontSize="13"
                                                    Margin="0,4,0,0"
                                                    Visibility="Collapsed"
                                                    Click="NiDetailSetTargetButton_Click"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="{DynamicResource SecondaryBg}"
                                    BorderBrush="{DynamicResource BorderDefault}"
                                    BorderThickness="0,1,0,0"
                                    Height="32">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                        <ProgressBar x:Name="NiProgressBar"
                                                     Width="160"
                                                     Height="8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"
                                                     Visibility="Collapsed"/>
                                        <TextBlock x:Name="NiStatusText"
                                                   Text="Ready — click Start discovery"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                        <TextBlock x:Name="NiBulkProbeStatusText"
                                                   Visibility="Collapsed"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentBlue}"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock x:Name="NiNodeCountText"
                                               Grid.Column="1"
                                               Text="0 nodes  0 edges  0 flows"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="8,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem x:Name="AdvancedTab" Header="Advanced Settings" PreviewMouseDown="AdvancedTab_PreviewMouseDown">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0" HorizontalAlignment="Stretch">
                            <StackPanel Grid.IsSharedSizeScope="True" HorizontalAlignment="Stretch">

                                <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
                                    <StackPanel HorizontalAlignment="Stretch">
                                        <TextBlock Text="Network Configuration" Style="{StaticResource CardHeaderStyle}"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="NIC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <ComboBox x:Name="AdvNetworkInterfaceComboBox"
                                                      Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                                      Margin="0,0,0,10"
                                                      SelectionChanged="NetworkInterfaceComboBox_SelectionChanged"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Source IP:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="AdvSourceIpTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     IsReadOnly="True"/>
                                            <Button x:Name="AdvRefreshSourceIpButton"
                                                    Grid.Row="1" Grid.Column="2"
                                                    Content="Refresh"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="RefreshSourceIpButton_Click"
                                                    ToolTip="Refresh source IP from selected network interface"/>

                                            <Label Grid.Row="2" Grid.Column="0" Content="Source MAC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="AdvSourceMacTextBox"
                                                     Grid.Row="2" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,0,10"
                                                     IsReadOnly="True"/>

                                            <Label Grid.Row="3" Grid.Column="0" Content="Gateway IP:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"/>
                                            <TextBox x:Name="AdvGatewayIpTextBox"
                                                     Grid.Row="3" Grid.Column="1"
                                                     Height="30"
                                                     IsReadOnly="True"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Target Configuration" Style="{StaticResource CardHeaderStyle}"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="Target IP:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"/>
                                            <TextBox x:Name="AdvTargetIpTextBox"
                                                     Grid.Row="0" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     Background="{DynamicResource InputBg}"
                                                     Foreground="{DynamicResource TextPrimary}"
                                                     BorderBrush="{DynamicResource BorderDefault}"
                                                     TextChanged="TargetIpTextBox_TextChanged"/>
                                            <Button x:Name="AdvPingButton"
                                                    Grid.Row="0" Grid.Column="2"
                                                    Content="Ping"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="PingButton_Click"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Dest./Next-hop MAC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"
                                                   ToolTip="On-link target: destination host MAC. Routed target: next-hop gateway MAC (remote host MAC is not reachable across routed hops)."/>
                                            <TextBox x:Name="AdvTargetMacTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     Margin="0,0,8,10"
                                                     IsReadOnly="True"
                                                     TextChanged="TargetMacTextBox_TextChanged"/>
                                            <Button x:Name="AdvResolveMacButton"
                                                    Grid.Row="1" Grid.Column="2"
                                                    Content="Resolve"
                                                    Width="80"
                                                    Height="30"
                                                    Margin="0,0,0,10"
                                                    Click="ResolveMacButton_Click"/>

                                            <CheckBox x:Name="AdvMacFallbackCheckBox"
                                                      Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                      Content="Allow manual MAC entry"
                                                      Margin="0,0,0,4"
                                                      Checked="MacFallbackCheckBox_Checked"
                                                      Unchecked="MacFallbackCheckBox_Unchecked"/>

                                            <TextBlock x:Name="AdvMacRouteHintText"
                                                       Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,0,0,8"
                                                       Visibility="Collapsed"/>

                                            <Label Grid.Row="4" Grid.Column="0" Content="Target Port:"
                                                   VerticalAlignment="Top"
                                                   Margin="0,0,16,0"/>
                                            <Grid Grid.Row="4" Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBox x:Name="AdvTargetPortTextBox"
                                                         Height="30"
                                                         Margin="0,0,8,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         Text="0"/>
                                                <ProgressBar x:Name="AdvScanProgressBar"
                                                             Grid.Row="1"
                                                             Height="5"
                                                             Margin="0,4,8,0"
                                                             Visibility="Collapsed"/>
                                            </Grid>
                                            <Button x:Name="AdvScanButton"
                                                    Grid.Row="4" Grid.Column="2"
                                                    Content="Scan"
                                                    Width="80"
                                                    Height="30"
                                                    VerticalAlignment="Top"
                                                    Click="ScanButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Attack Configuration" Style="{StaticResource CardHeaderStyle}"/>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" Content="Attack Type:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"/>
                                            <ComboBox x:Name="AdvancedAttackTypeComboBox"
                                                      Grid.Column="1"
                                                      Height="30"
                                                      SelectionChanged="AdvancedAttackTypeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="ARP Spoofing"/>
                                            <ComboBoxItem Content="NMEA 0183 (UDP Unicast)"/>
                                            <ComboBoxItem Content="NMEA 0183 (UDP Multicast)"/>
                                            <ComboBoxItem Content="Modbus/TCP Flood (Read Requests)"/>
                                            </ComboBox>
                                        </Grid>

                                        <Grid Margin="0,4,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,10"
                                                   Content="Rate:">
                                                <Label.ToolTip>
                                                    <ToolTip>
                                                        <TextBlock TextWrapping="Wrap" MaxWidth="320">
                                                            Wire-rate target at L2 (Ethernet header + payload + FCS).
                                                            Select unit in the dropdown. Supports Mbps, Kbps, and Bps.
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Label.ToolTip>
                                            </Label>
                                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="AdvMegabitsPerSecondTextBox"
                                                         Grid.Column="0"
                                                         Height="30"
                                                         Margin="0,0,4,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         PreviewTextInput="AdvMegabitsPerSecondTextBox_PreviewTextInput"
                                                         TextChanged="AdvMegabitsPerSecondTextBox_TextChanged"
                                                         Text="100"
                                                         ToolTip="Enter target rate value"/>
                                                <ComboBox x:Name="AdvRateUnitComboBox"
                                                          Grid.Column="1"
                                                          Height="30"
                                                          Padding="6,0"
                                                          ToolTip="Select rate unit"
                                                          SelectionChanged="AdvRateUnitComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Bps"/>
                                                    <ComboBoxItem Content="Kbps"/>
                                                    <ComboBoxItem Content="Mbps" IsSelected="True"/>
                                                    <ComboBoxItem Content="Gbps"/>
                                                </ComboBox>
                                            </Grid>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Spoofed MAC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"/>
                                            <TextBox x:Name="SpoofedMacTextBox"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Height="30"
                                                     TextChanged="SpoofedMacTextBox_TextChanged"
                                                     MaxLength="17"
                                                     Text="12:34:56:78:90:AB"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <Expander Header="TCP SYN Advanced Options"
                                              Foreground="{DynamicResource TextPrimary}"
                                              FontSize="12"
                                              FontWeight="SemiBold"
                                              IsExpanded="False">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="Override the selected Attack Mode. Checkboxes are OR-ed on top of the mode's defaults."
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>
                                            <CheckBox x:Name="FirewallBypassModeCheckBox"
                                                      Content="Firewall Bypass Mode (randomise IP ID / TTL / window / MSS / timestamps)"
                                                      Margin="0,0,0,6"
                                                      ToolTip="Builds per-packet Linux-style 20-byte SYN options to defeat default-policy firewall drops"
                                                      Checked="FirewallBypassModeCheckBox_Changed"
                                                      Unchecked="FirewallBypassModeCheckBox_Changed"/>
                                            <CheckBox x:Name="ForceSoftwareChecksumCheckBox"
                                                      Content="Force software IP/TCP checksums before transmit"
                                                      Margin="0,0,0,6"
                                                      ToolTip="Recompute checksums in software even though raw injection already bypasses NIC offload"
                                                      Checked="ForceSoftwareChecksumCheckBox_Changed"
                                                      Unchecked="ForceSoftwareChecksumCheckBox_Changed"/>
                                            <CheckBox x:Name="UseRealSourceIpCheckBox"
                                                      Content="Use real source IP (disable spoofing — defeats uRPF)"
                                                      Margin="0,0,0,6"
                                                      ToolTip="When checked, SpoofSourceIp is ignored and the NIC's actual IP is used"
                                                      Checked="UseRealSourceIpCheckBox_Changed"
                                                      Unchecked="UseRealSourceIpCheckBox_Changed"/>
                                            <CheckBox x:Name="RandomizeWithinSubnetCheckBox"
                                                      Content="Randomise spoofed source within local /24 subnet"
                                                      ToolTip="Confines spoofed source IPs to the NIC's /24 — only applies when 'Use real source IP' is off"
                                                      Checked="RandomizeWithinSubnetCheckBox_Changed"
                                                      Unchecked="RandomizeWithinSubnetCheckBox_Changed"/>
                                        </StackPanel>
                                    </Expander>
                                </Border>

                                <Border Margin="0,4,0,0"
                                        Padding="16,14"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderDefault}"
                                        BorderThickness="1"
                                        Background="{DynamicResource SecondaryBg}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Label Content="Password:"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   Margin="0,0,8,0"
                                                   Padding="0"
                                                   VerticalAlignment="Center"/>
                                            <PasswordBox x:Name="AdvPasswordBox"
                                                         Width="160"
                                                         Height="30"
                                                         Margin="0,0,8,0"
                                                         VerticalContentAlignment="Center"
                                                         FontSize="13"
                                                         Padding="8,0"
                                                         PasswordChanged="PasswordBox_PasswordChanged"
                                                         KeyDown="PasswordBox_KeyDown"
                                                         ToolTip="Enter password to enable attack controls (Press Enter to validate)"/>
                                            <Button x:Name="AdvValidatePasswordButton"
                                                    Content="Validate"
                                                    Width="100"
                                                    Height="30"
                                                    FontSize="13"
                                                    FontWeight="Medium"
                                                    Click="ValidatePasswordButton_Click"
                                                    ToolTip="Click to validate password"/>
                                        </StackPanel>
                                        <TextBlock x:Name="PasswordFeedbackText"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ErrorRed}"
                                                   Margin="0,0,0,10"
                                                   Visibility="Collapsed"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button x:Name="StartAdvancedAttackButton"
                                                    Content="▶  Start Attack"
                                                    Width="148"
                                                    Height="36"
                                                    Style="{StaticResource PrimaryButton}"
                                                    IsEnabled="False"
                                                    Click="StartAdvancedAttack_Click"/>
                                            <Button x:Name="StopAdvancedAttackButton"
                                                    Content="■  Stop Attack"
                                                    Width="120"
                                                    Height="36"
                                                    Margin="8,0,0,0"
                                                    IsEnabled="False"
                                                    Click="StopAdvancedAttack_Click"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button x:Name="TraceRouteAdvancedButton"
                                                    Content="Trace Route"
                                                    Width="120"
                                                    Height="30"
                                                    Click="TraceRouteButton_Click"/>
                                            <Button x:Name="NetworkScanAdvancedButton"
                                                    Content="Network Scan"
                                                    Width="120"
                                                    Height="30"
                                                    Margin="8,0,0,0"
                                                    Click="NetworkScanButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <Grid x:Name="SecurityLogPanel" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,16"
                                VerticalAlignment="Center">
                        <TextBlock Text="Security Logs"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Margin="0,0,16,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Button x:Name="TaskManagerButton"
                                Content="Task Manager"
                                Width="120"
                                Height="30"
                                VerticalAlignment="Center"
                                Click="TaskManagerButton_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NoteTextBox"
                                         Grid.Column="0"
                                         Height="50"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text=""
                                         GotFocus="NoteTextBox_GotFocus"
                                         LostFocus="NoteTextBox_LostFocus"
                                         Margin="0,0,12,0"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource BorderDefault}"
                                         Foreground="{DynamicResource TextMuted}"/>
                                <Button x:Name="AddNoteButton"
                                        Grid.Column="1"
                                        Content="Add Note"
                                        Width="100"
                                        Height="50"
                                        Click="AddNoteButton_Click"/>
                            </Grid>

                            <Border Grid.Row="1"
                                    BorderBrush="{DynamicResource BorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Background="{DynamicResource PrimaryBg}"
                                    Margin="0,0,0,16">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                    <TextBox x:Name="LogTextBox"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextCode}"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             VerticalScrollBarVisibility="Disabled"/>
                                </ScrollViewer>
                            </Border>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="SaveLogButton"
                                        Content="Save Log"
                                        Width="100"
                                        Height="30"
                                        Margin="0,0,12,0"
                                        Click="SaveLogButton_Click"/>
                                <Button x:Name="ClearLogButton"
                                        Content="Clear Log"
                                        Width="100"
                                        Height="30"
                                        Click="ClearLogButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <StackPanel x:Name="ToastContainer"
                    Grid.Row="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,20,20,0"
                    Panel.ZIndex="9999"/>

    </Grid>
</Window>
