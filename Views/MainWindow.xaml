                                                        Tag="Basic"
                                                        Style="{StaticResource ProtocolCardStyle}"
                                                        MouseLeftButtonUp="TcpSynModeCard_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="Basic"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                        <TextBlock Text="Standard SYN — max throughput"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   Margin="0,2,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="EvasionModeCard"
                                                        Tag="Evasion"
                                                        Style="{StaticResource ProtocolCardStyle}"
                                                        MouseLeftButtonUp="TcpSynModeCard_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="Evasion"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                        <TextBlock Text="Firewall bypass — randomised headers"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   Margin="0,2,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>
                                            <TextBlock x:Name="TcpSynModeDescText"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Margin="4,8,0,0"
                                                       Text="Standard TCP SYN packets. Best for raw throughput tests against session tables."/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,4,0,0"
                                        Padding="16,14"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource BorderDefault}"
                                        BorderThickness="1"
                                        Background="{StaticResource SecondaryBg}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button x:Name="StartButton"
                                                    Content="▶  Start Test"
                                                    Width="148"
                                                    Height="36"
                                                    Style="{StaticResource PrimaryButton}"
