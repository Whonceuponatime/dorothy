                                                    <TextBlock Text="Ethernet Unicast" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="L2 IPv4 storm" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Tag="5" Style="{StaticResource ProtocolCardStyle}" MouseLeftButtonUp="ProtocolCard_Click">
