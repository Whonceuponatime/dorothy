                                                    <TextBlock Text="Ethernet Broadcast" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="L2 IPv4 broadcast" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
