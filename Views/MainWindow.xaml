                    <TabItem x:Name="FirewallNetworksTab" Header="Reachability Tests">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,16,0,12"
                                    Background="#2a1f05"
                                    BorderBrush="{StaticResource WarningAmber}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="16,12">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource WarningAmber}">
                                    <Run Text="⚠  " FontWeight="Bold"/>
                                    <Run Text="Use only on networks and systems you are explicitly authorized to test. This feature performs active scanning."/>
                                </TextBlock>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,0,0" HorizontalAlignment="Stretch">
                                <StackPanel Grid.IsSharedSizeScope="True" HorizontalAlignment="Stretch">
                                    <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock Text="Simple Reachability Test" Style="{StaticResource CardHeaderStyle}"/>
                                            <TextBlock Text="Test reachability to a single host: ICMP ping, TCP port check, and path analysis. Best for quick targeted checks."
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                            <Button x:Name="ReachabilityPathAnalysisButton"
                                                    Content="Simple Reachability Test…"
                                                    MinWidth="220"
                                                    MinHeight="36"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="ReachabilityPathAnalysisButton_Click"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock Text="Bounded TCP Connect Scan" Style="{StaticResource CardHeaderStyle}"/>
                                            <TextBlock Text="Scan a single IP, IP range, CIDR, or imported list using standard TCP connect probing. Concurrency-limited and cancelable. Authorized use only."
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                            <Button x:Name="BoundedTcpScanButton"
                                                    Content="Bounded TCP Connect Scan…"
                                                    MinWidth="240"
                                                    MinHeight="36"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="BoundedTcpScanButton_Click"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock Text="SNMP Walk Attack" Style="{StaticResource CardHeaderStyle}"/>
                                            <TextBlock Text="Performs SNMP walk operations using 100 common community strings to test SNMP access."
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Label Grid.Row="0" Grid.Column="0" Content="Target IP:" VerticalAlignment="Center" Margin="0,0,16,10"/>
                                                <TextBox x:Name="SnmpWalkTargetIpTextBox" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,10"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"/>
                                                <Label Grid.Row="1" Grid.Column="0" Content="SNMP Port:" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                <TextBox x:Name="SnmpWalkPortTextBox" Grid.Row="1" Grid.Column="1" Height="30" Text="161"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Left">
                                                <Button x:Name="StartSnmpWalkButton"
                                                        Content="Start SNMP Walk"
                                                        Width="150" Height="34"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Click="StartSnmpWalkButton_Click"
                                                        Margin="0,0,12,0"/>
                                                <Button x:Name="StopSnmpWalkButton"
                                                        Content="Stop"
                                                        Width="100" Height="34"
                                                        Click="StopSnmpWalkButton_Click"
                                                        IsEnabled="False"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="SnmpWalkProgressBar" Height="6" Margin="0,12,0,0" Visibility="Collapsed" Maximum="100" Value="0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2"
                                    Style="{StaticResource CardStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,12,0,0"
                                    x:Name="SecurityAssessmentStatusBorder"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Security Assessment" Style="{StaticResource CardHeaderStyle}"/>
                                    <TextBlock x:Name="SecurityAssessmentStatusTextBlock"
                                               FontSize="13"
                                               Foreground="{StaticResource SuccessGreen}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,16"
                                VerticalAlignment="Center">
                        <TextBlock Text="Security Logs"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Margin="0,0,16,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <Button x:Name="TaskManagerButton"
                                Content="Task Manager"
                                Width="120"
                                Height="30"
                                VerticalAlignment="Center"
                                Click="TaskManagerButton_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NoteTextBox"
                                         Grid.Column="0"
                                         Height="50"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text=""
                                         GotFocus="NoteTextBox_GotFocus"
                                         LostFocus="NoteTextBox_LostFocus"
                                         Margin="0,0,12,0"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource BorderDefault}"
                                         Foreground="{DynamicResource TextMuted}"/>
                                <Button x:Name="AddNoteButton"
                                        Grid.Column="1"
                                        Content="Add Note"
                                        Width="100"
                                        Height="50"
                                        Click="AddNoteButton_Click"/>
                            </Grid>

                            <Border Grid.Row="1"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Background="{StaticResource PrimaryBg}"
                                    Margin="0,0,0,16">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                    <TextBox x:Name="LogTextBox"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{StaticResource TextCode}"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             VerticalScrollBarVisibility="Disabled"/>
                                </ScrollViewer>
                            </Border>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="SaveLogButton"
                                        Content="Save Log"
                                        Width="100"
                                        Height="30"
                                        Margin="0,0,12,0"
                                        Click="SaveLogButton_Click"/>
                                <Button x:Name="ClearLogButton"
                                        Content="Clear Log"
                                        Width="100"
                                        Height="30"
                                        Click="ClearLogButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <StackPanel x:Name="ToastContainer"
                    Grid.Row="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,20,20,0"
                    Panel.ZIndex="9999"/>

        <Border x:Name="SyncLoadingOverlay"
                Grid.Row="0"
                Background="#B0000000"
                Visibility="Collapsed"
                Panel.ZIndex="10000">
            <Border Background="{StaticResource SecondaryBg}"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="300">
                <StackPanel>
                    <TextBlock Text="Syncing to Cloud..."
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="SyncProgressBar"
                                 IsIndeterminate="True"
                                 Height="6"
                                 Margin="0,0,0,12"/>
                    <TextBlock x:Name="SyncProgressText"
                               Text="Preparing sync..."
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
