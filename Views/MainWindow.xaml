                                                            Select unit in the dropdown. Supports Mbps, Kbps, and Bps.
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Label.ToolTip>
                                            </Label>
                                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="AdvMegabitsPerSecondTextBox"
                                                         Grid.Column="0"
                                                         Height="30"
                                                         Margin="0,0,4,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         PreviewTextInput="AdvMegabitsPerSecondTextBox_PreviewTextInput"
                                                         TextChanged="AdvMegabitsPerSecondTextBox_TextChanged"
                                                         Text="100"
                                                         ToolTip="Enter target rate value"/>
                                                <ComboBox x:Name="AdvRateUnitComboBox"
                                                          Grid.Column="1"
                                                          Height="30"
                                                          Padding="6,0"
                                                          ToolTip="Select rate unit"
                                                          SelectionChanged="AdvRateUnitComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Bps"/>
                                                    <ComboBoxItem Content="Kbps"/>
                                                    <ComboBoxItem Content="Mbps" IsSelected="True"/>
                                                    <ComboBoxItem Content="Gbps"/>
                                                </ComboBox>
                                            </Grid>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Spoofed MAC:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"/>
