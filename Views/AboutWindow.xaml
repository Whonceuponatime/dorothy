<Window x:Class="Dorothy.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SEACURE(TOOL)"
        Icon="pack://application:,,,/Resources/icon.ico"
        Height="560"
        Width="640"
        MinWidth="480"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource PrimaryBg}"
        Foreground="{DynamicResource TextPrimary}"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="About SEACURE(TOOL)"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Application Info"
                       FontSize="12"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource SecondaryBg}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="ProductVersionText"
                                   Text="SEACURE(TOOL) - Version 2.5.0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                        <Border x:Name="VersionStatusBadge"
                                Background="{DynamicResource SuccessBgSubtle}"
                                CornerRadius="4"
                                Padding="6,2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock x:Name="VersionStatusText"
                                       Text=""
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource SuccessGreen}"/>
                        </Border>
                    </StackPanel>

                    <Border x:Name="UpdateAvailableBorder"
                            Background="{DynamicResource AccentBlueSubtle}"
                            BorderBrush="{DynamicResource LabModeBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="UpdateMessageText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource InfoBlue}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="DownloadUpdateButton"
                                    Content="Download Update"
                                    Width="150"
                                    Height="32"
                                    FontSize="12"
                                    Background="{DynamicResource AccentBlue}"
                                    Foreground="{DynamicResource ButtonPrimaryFg}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="DownloadUpdateButton_Click"
                                    HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="12,8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="SEACURE(TOOL) is a professional network security testing tool designed for authorized penetration testing and security assessment."
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"
                               LineHeight="20"/>

                    <TextBlock Text="Attack Types"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="• TCP SYN Flood, UDP Flood, ICMP Flood&#x0a;• ARP Spoofing&#x0a;• Ethernet-level attacks (Unicast, Multicast, Broadcast)&#x0a;• NMEA 0183 UDP attacks (Unicast, Multicast)"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               LineHeight="20"/>

                    <TextBlock Text="Capabilities"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="• Configurable attack rates and parameters&#x0a;• Real-time statistics and logging&#x0a;• Network interface selection and gateway routing&#x0a;• Network scanning and asset inventory"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               LineHeight="20"/>

                    <TextBlock Text="Integration"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="• Cloud sync with the Seacure licensing server&#x0a;• Security logs with export capabilities"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"
                               LineHeight="20"/>

                    <Border Background="{DynamicResource FieldWarningBg}"
                            BorderBrush="{DynamicResource FieldWarningBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,8,0,0">
                        <TextBlock Text="⚠ Authorized Use Only&#x0a;This tool is for AUTHORIZED TESTING ONLY. Use only in controlled lab/test environments. Unauthorized use may be illegal and result in disciplinary or legal action."
                                   FontSize="11"
                                   Foreground="{DynamicResource WarningAmber}"
                                   TextWrapping="Wrap"
                                   LineHeight="18"/>
                    </Border>

                    <TextBlock Margin="0,20,0,0">
                        <Run Text="For more information, visit: "
                             FontSize="12"
                             Foreground="{DynamicResource TextMuted}"/>
                        <Hyperlink x:Name="WebsiteLink"
                                   NavigateUri="https://www.sea-net.co.kr/seacure"
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentBlue}"
                                   RequestNavigate="WebsiteLink_RequestNavigate">
                            <Run Text="https://www.sea-net.co.kr/seacure"/>
                        </Hyperlink>
                    </TextBlock>

                    <Border BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="0,1,0,0"
                            Margin="0,20,0,12"/>

                    <TextBlock HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,0">
                        <Run Text="Copyright(C) SeaNet Co., Ltd. All right reserved"
                             FontSize="10"
                             Foreground="{DynamicResource DisabledFg}"/>
                        <LineBreak/>
                        <Hyperlink NavigateUri="https://www.sea-net.co.kr/seacure"
                                   FontSize="10"
                                   Foreground="{DynamicResource AccentBlue}"
                                   RequestNavigate="WebsiteLink_RequestNavigate">
                            <Run Text="www.sea-net.co.kr/seacure"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CloseButton"
                        Content="Close"
                        MinWidth="100"
                        Height="36"
                        Click="CloseButton_Click"
                        Background="{DynamicResource AccentBlue}"
                        Foreground="{DynamicResource ButtonPrimaryFg}"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="12,8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
