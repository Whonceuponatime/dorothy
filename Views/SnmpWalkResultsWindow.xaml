<Window x:Class="Dorothy.Views.SnmpWalkResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SNMP Walk Results"
        Icon="pack://application:,,,/Resources/icon.ico"
        Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBg}">
    <Window.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBg}"/>
        </Style>

        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="DefaultButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHover}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TertiaryBg}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource SecondaryBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DefaultButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="HeaderTextBlock"
                       Text="SNMP Walk Results"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="SummaryTextBlock"
                       FontSize="14"
                       Foreground="{DynamicResource TextMuted}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border x:Name="SuccessCard"
                        Style="{StaticResource CardStyle}"
                        Background="{DynamicResource FieldWarningBg}"
                        BorderBrush="{DynamicResource FieldWarningBorder}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️ SNMP Vulnerability Found"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningAmber}"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="VulnerabilityDetailsTextBlock"
                                   FontSize="14"
                                   Foreground="{DynamicResource WarningAmber}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="OIDs Retrieved:"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningAmber}"
                                   Margin="0,0,0,8"/>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="OidsTextBlock"
                                       FontSize="12"
                                       Foreground="{DynamicResource WarningAmber}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border x:Name="SecureCard"
                        Style="{StaticResource CardStyle}"
                        Background="{DynamicResource SuccessBgSubtle}"
                        BorderBrush="{DynamicResource SuccessBorder}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="✓ SNMP Secure"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessGreen}"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="SecureDetailsTextBlock"
                                   FontSize="14"
                                   Foreground="{DynamicResource SuccessGreen}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CloseButton"
                    Content="Close"
                    Width="100"
                    Height="36"
                    Style="{StaticResource PrimaryButton}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

