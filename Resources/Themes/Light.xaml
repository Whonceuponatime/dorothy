<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Dorothy;component/Resources/Themes/Base.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Core surfaces -->
    <SolidColorBrush x:Key="PrimaryBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryBg"     Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TertiaryBg"      Color="#F1F5F9"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderDefault"   Color="#CBD5E1"/>
    <SolidColorBrush x:Key="BorderHover"     Color="#94A3B8"/>
    <SolidColorBrush x:Key="CardBorder"      Color="#CBD5E1"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"     Color="#0F172A"/>
    <SolidColorBrush x:Key="TextSecondary"   Color="#475569"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#64748B"/>
    <SolidColorBrush x:Key="TextCode"        Color="#475569"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBlue"       Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentBlueHover"  Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentBlueSubtle" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="InfoBlue"         Color="#2563EB"/>
    <SolidColorBrush x:Key="SuccessGreen"    Color="#16A34A"/>
    <SolidColorBrush x:Key="WarningAmber"    Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorRed"        Color="#DC2626"/>

    <!-- Inputs / buttons -->
    <SolidColorBrush x:Key="InputBg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputHoverBg"    Color="#F8FAFC"/>
    <SolidColorBrush x:Key="ButtonHoverBg"   Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ButtonPrimaryFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DisabledFg"      Color="#94A3B8"/>

    <!-- Status subtle backgrounds -->
    <SolidColorBrush x:Key="SuccessBgSubtle" Color="#F0FDF4"/>
    <SolidColorBrush x:Key="SuccessBorder"   Color="#16A34A"/>
    <SolidColorBrush x:Key="ErrorBgSubtle"   Color="#FEF2F2"/>

    <!-- Resolved (IsReadOnly TextBox) — green-on-light -->
    <SolidColorBrush x:Key="ResolvedFg"      Color="#16A34A"/>
    <SolidColorBrush x:Key="ResolvedBg"      Color="#F0FDF4"/>
    <SolidColorBrush x:Key="ResolvedBorder"  Color="#86EFAC"/>

    <!-- Logo surround (lighter blue block, visible on white) -->
    <SolidColorBrush x:Key="LogoBg"          Color="#EFF6FF"/>
    <SolidColorBrush x:Key="LogoBorder"      Color="#BFDBFE"/>
    <SolidColorBrush x:Key="LogoFg"          Color="#1E40AF"/>

    <!-- LAB MODE badge -->
    <SolidColorBrush x:Key="LabModeBg"       Color="#EFF6FF"/>
    <SolidColorBrush x:Key="LabModeFg"       Color="#1D4ED8"/>
    <SolidColorBrush x:Key="LabModeBorder"   Color="#93C5FD"/>

    <!-- Semantic field states -->
    <SolidColorBrush x:Key="FieldNormalBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FieldNormalFg"      Color="#0F172A"/>
    <SolidColorBrush x:Key="FieldNormalBorder"  Color="#E2E8F0"/>

    <SolidColorBrush x:Key="FieldWarningBg"     Color="#FEF3C7"/>
    <SolidColorBrush x:Key="FieldWarningFg"     Color="#92400E"/>
    <SolidColorBrush x:Key="FieldWarningBorder" Color="#F59E0B"/>

    <SolidColorBrush x:Key="FieldErrorBg"       Color="#FEE2E2"/>
    <SolidColorBrush x:Key="FieldErrorFg"       Color="#991B1B"/>
    <SolidColorBrush x:Key="FieldErrorBorder"   Color="#F87171"/>

    <SolidColorBrush x:Key="FieldSuccessBg"     Color="#DCFCE7"/>
    <SolidColorBrush x:Key="FieldSuccessFg"     Color="#14532D"/>
    <SolidColorBrush x:Key="FieldSuccessBorder" Color="#16A34A"/>

    <SolidColorBrush x:Key="FieldInfoBg"        Color="#DBEAFE"/>
    <SolidColorBrush x:Key="FieldInfoFg"        Color="#1E3A8A"/>
    <SolidColorBrush x:Key="FieldInfoBorder"    Color="#3B82F6"/>

    <SolidColorBrush x:Key="FieldDisabledBg"    Color="#F1F5F9"/>
    <SolidColorBrush x:Key="FieldDisabledFg"    Color="#94A3B8"/>

</ResourceDictionary>
